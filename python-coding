# First Non-Repeating Character
def fornonrepfirstchar(arr):
    for i in arr:
        if arr.count(i) == 1:
            return i
    return None


print("\n2. First Non-Repeating Character")
print("-" * 30)
print(fornonrepfirstchar(['a', 'b', 'c', 'c', 'a']))
