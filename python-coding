# Find Matching Log Line
def gettxtline(txt, keyword):
    for line in txt.splitlines():
        if keyword.lower() in line.lower():
            return line
    return None


txt = """12-21-2026 9:51am not connecting the database
12-21-2026 10:15am database connection restored
12-21-2026 11:30am API timeout issue detected
12-21-2026 12:00pm API service restarted
"""


print("\n3. Log Search")
